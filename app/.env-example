# ---------------------------------------------------------------------------
# Provider API Keys
# Install the matching Python package when switching providers:
#   OpenAI (default): already included via openai>=1.x
#   Anthropic:        pip install anthropic
#   Google:           pip install google-generativeai
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
LOG_LEVEL=debug

# for LOCAL DEVELOPMENT (local Supabase instance) with symmetric key JWT signing:
# if JWT_USE_SECRET is true, JWT_SECRET will be used for HS256 signing
# if JWT_USE_SECRET is false or unspecified, JWT_JWKS_URL will be used for RS256
JWT_USE_SECRET=true
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_ISSUER=http://127.0.0.1:54321/auth/v1

# ---------------------------------------------------------------------------
# LLM Model Configuration
#
# Model strings use the pydantic-ai provider-prefix format:
#   "<provider>:<model-name>"
#
# Supported provider prefixes:
#   openai:      e.g. openai:gpt-5.2             (requires OPENAI_API_KEY)
#   anthropic:   e.g. anthropic:claude-sonnet-4   (requires ANTHROPIC_API_KEY)
#   google-gla:  e.g. google-gla:gemini-2.5-pro   (requires GOOGLE_API_KEY)
#
# Image/video generation model strings do NOT use the provider prefix --
# they are bare model names passed directly to the provider API:
#   gpt-image-1.5  (OpenAI)
#   sora-2         (OpenAI)
#
# Role-based tiers (defaults are Anthropic; override to change):
# LUCY_MODEL_AGENT_PRIMARY=anthropic:claude-sonnet-4-6
# LUCY_MODEL_AGENT_FAST=anthropic:claude-haiku-4-5-20251001
# LUCY_MODEL_AGENT_NANO=anthropic:claude-haiku-4-5-20251001
# LUCY_MODEL_IMAGE_GEN=gpt-image-1.5
# LUCY_MODEL_VIDEO_GEN=sora-2
#
# PDF file analysis must stay on OpenAI (uses OpenAI Files API):
# LUCY_MODEL_FILE_PDF=openai:gpt-5
# LUCY_MODEL_FILE_DEFAULT=openai:gpt-5-mini
#
# Optional per-agent overrides:
# LUCY_MODEL_ROUTER=anthropic:claude-haiku-4-20250514
# LUCY_MODEL_TITLE=anthropic:claude-haiku-4-20250514
# LUCY_MODEL_SUPPORT=anthropic:claude-sonnet-4-20250514
# LUCY_MODEL_KEYWORDS=anthropic:claude-sonnet-4-20250514
# LUCY_MODEL_IMAGE=anthropic:claude-sonnet-4-20250514
# LUCY_MODEL_VIDEO=anthropic:claude-sonnet-4-20250514
# LUCY_MODEL_PERFORMANCE=anthropic:claude-sonnet-4-20250514
# LUCY_MODEL_CAMPAIGN_PLANNER=anthropic:claude-sonnet-4-20250514
# LUCY_MODEL_CD_ROUTER=anthropic:claude-haiku-4-20250514
# LUCY_MODEL_PERF_EXTRACTION=anthropic:claude-haiku-4-20250514

# ---------------------------------------------------------------------------
# Extended Thinking
#
# Anthropic extended thinking is enabled by default for all chat requests.
# Set LUCY_DISABLE_THINKING=true to turn it off (e.g. to reduce cost/latency).
#
# Only applies to Anthropic models. Ignored silently for OpenAI models.
# ---------------------------------------------------------------------------
# LUCY_DISABLE_THINKING=true

# Token budget for extended thinking (used when thinking is enabled).
# Anthropic bills these as output tokens. Higher budgets allow more complex
# reasoning but increase cost and latency.
# ---------------------------------------------------------------------------
# LUCY_THINKING_BUDGET=10000

# ---------------------------------------------------------------------------
# Orchestration (Workflow 2)
# ---------------------------------------------------------------------------
# ORCHESTRATION_MAX_PARALLEL_TASKS=4
# ORCHESTRATION_CHECKPOINT_TIMEOUT_S=86400

# ---------------------------------------------------------------------------
# Data pipeline (L0→L4)
# ---------------------------------------------------------------------------
# PIPELINE_RAW_S3_BUCKET=
# PIPELINE_RAW_S3_PREFIX=l1-raw
# PIPELINE_RESTATEMENT_DAYS=7
# PIPELINE_REPORTING_TIMEZONE=America/New_York
# PIPELINE_REPORTING_CURRENCY=USD

# Google Ads (also used by Lofi edge functions locally)
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_MANAGER_CUSTOMER_ID=

# Meta Marketing API
# META_APP_ID=
# META_APP_SECRET=
# META_ACCESS_TOKEN=

# TikTok Business API
# TIKTOK_APP_ID=
# TIKTOK_APP_SECRET=
# TIKTOK_ACCESS_TOKEN=

# Spotify Ads API
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REFRESH_TOKEN=

# ---------------------------------------------------------------------------
# Competitive intelligence (SearchAPI.io)
# ---------------------------------------------------------------------------
# SEARCHAPI_API_KEY=

# ---------------------------------------------------------------------------
# Evaluation framework
# ---------------------------------------------------------------------------
# EVAL_REGRESSION_THRESHOLD=0.05
# EVAL_CI_MODE=false
